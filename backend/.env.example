# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=ninja_clan_db

# JWT配置
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# 应用配置
PORT=5000
NODE_ENV=development
API_BASE_URL=/api/v1
# 浏览器访问地址（生产填 https://你的域名 或 http://公网IP；须与 CORS 一致）
FRONTEND_URL=http://localhost:3000
# 多个来源用英文逗号分隔，生产示例：http://47.95.218.23,https://你的域名
CORS_ORIGIN=http://localhost:3000

# 文件上传配置
MAX_FILE_SIZE=10485760 # 10MB
UPLOAD_PATH=./uploads
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 游戏相关配置
GAME_CLAN_ID=your_clan_id_here
GAME_API_KEY=your_game_api_key_here

# 定时任务配置
CRON_UPDATE_FOUR_ELEMENTS=0 0 * * 4 # 每周四凌晨更新四象顺序
CRON_CLEANUP_OLD_LOGS=0 2 * * * # 每天凌晨2点清理旧日志