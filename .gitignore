logs/
*.log

# 运行时数据
data/
*.pid
*.seed
*.pid.lock

# 覆盖率报告
coverage/
.nyc_output/

# 缓存
.cache/

# 临时文件
tmp/
temp/
*.tmp
*.temp

# IDE相关
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
desktop.ini

# 测试快照
__snapshots__/

